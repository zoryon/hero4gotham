# Database connection string
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://user:password@127.0.0.1:5432/your-database-name

# You can use: $ openssl rand -hex 32
# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# SMTP email. Defaults in code target IONOS: smtp.ionos.it, port 587, STARTTLS.
SMTP_HOST=smtp.ionos.it
SMTP_PORT=587
SMTP_REQUIRE_TLS=true
SMTP_SECURE=false
SMTP_USER=your-mailbox@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM_ADDRESS=your-mailbox@example.com
SMTP_FROM_NAME=Hero 4 Gotham
CONTACT_MESSAGE_TO=recipient@example.com
